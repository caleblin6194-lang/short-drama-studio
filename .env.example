# ============================================
# 短剧制作工具 — 环境变量配置示例
# 复制此文件为 .env.local 并填入真实密钥
# 本文件不要提交到 Git！
# ============================================

# ============================================
# 豆包 / 火山引擎（图像 + 视频生成）
# 获取: https://console.volcengine.com/ark → API Key
# ============================================
DOUBAN_SEED_API_KEY=your_doubao_api_key_here
DOUBAN_IMAGE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations
DOUBAN_MODEL=doubao-seedream-5-0-260128
SEED_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
SEED_MODEL=doubao-seedance-1-0-pro-250528

# ============================================
# OpenAI（字幕 ASR / 剧本地域变体翻译）
# 获取: https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=sk-your-openai-key

# ============================================
# Supabase（数据库 + 认证）
# 获取: https://supabase.com → Project Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# 功能开关
# NEXT_PUBLIC_ENABLE_REAL_PIPELINE=1 → 使用真实 API（需配置上方密钥）
# 不设置或设为 0 → 使用 Mock 数据（本地开发）
# ============================================
NEXT_PUBLIC_ENABLE_REAL_PIPELINE=0
ALLOW_DEMO_LOGIN=0

# ============================================
# Cloudinary（资产图片 CDN，可选）
# 获取: https://console.cloudinary.com → Settings → Access Keys
# ============================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# 腾讯 COS（视频存储，可选）
# 获取: https://console.cloud.tencent.com/cos
# ============================================
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your-bucket-1234567890
COS_REGION=ap-guangzhou
